# Ambiente da Receita Federal (opções: producao, producao_restrita, homologacao)
RF_AMBIENTE=homologacao

# Credenciais da API da Receita Federal (Obtidas no Portal Nacional da Tributação sobre Consumo)
RF_CLIENT_ID=seu_client_id_aqui
RF_CLIENT_SECRET=seu_client_secret_aqui

# URL base customizada da API (Opcional - se vazio, será inferido automaticamente a partir do RF_AMBIENTE)
# RF_BASE_URL=https://api.receitafederal.gov.br

# URL do seu Webhook publicado na Vercel (onde a Receita vai enviar o tiquete)
RF_WEBHOOK_URL=https://sua-api.vercel.app/api/webhook-receita

# Configurações de Integração local com o seu Webhook na nuvem
# WEBHOOK_SECRET: Token de segurança compartilhado entre o Motor Local e a Vercel (deve ser idêntico ao cadastrado na Vercel)
WEBHOOK_SECRET=token_secreto_compartilhado_aqui
VERCEL_API_URL=https://sua-api.vercel.app

# CNPJ padrão para processamento (Apenas números, 8 primeiros dígitos)
CNPJ_APURACAO=12345678
